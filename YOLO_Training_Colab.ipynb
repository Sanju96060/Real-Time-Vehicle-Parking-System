    "    'save_period': 10,\n",
    "    'project': 'vehicle_detection',\n",
    "    'name': 'yolov11_vehicle'\n",
    "}\n",
    "\n",
    "PLATE_CONFIG = {\n",
    "    'model': 'yolov11n.pt',  # Small model for faster training\n",
    "    'epochs': 50,\n",
    "    'batch_size': 16,\n",
    "    'img_size': 640,\n",
    "    'device': '0' if torch.cuda.is_available() else 'cpu',\n",
    "    'patience': 10,\n",
    "    'save_period': 10,\n",
    "    'project': 'number_plate_detection',\n",
    "    'name': 'yolov11_plate'\n",
    "}\n",
    "\n",
    "print(f\"🚀 Training Configuration:\")\n",
    "print(f\"Device: {VEHICLE_CONFIG['device']}\")\n",
    "print(f\"GPU Available: {torch.cuda.is_available()}\")\n",
    "if torch.cuda.is_available():\n",
    "    print(f\"GPU Name: {torch.cuda.get_device_name(0)}\")"
   ]
