    "## 🚗 Vehicle Detection Training"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Train Vehicle Detection Model\n",
    "if os.path.exists(vehicle_path):\n",
    "    print(\"🚗 Starting Vehicle Detection Training...\")\n",
    "    \n",
    "    # Load model\n",
    "    vehicle_model = YOLO(VEHICLE_CONFIG['model'])\n",
    "    \n",
    "    # Train model\n",
    "    results = vehicle_model.train(\n",
    "        data=os.path.join(vehicle_path, 'data.yaml'),\n",
    "        epochs=VEHICLE_CONFIG['epochs'],\n",
    "        batch=VEHICLE_CONFIG['batch_size'],\n",
    "        imgsz=VEHICLE_CONFIG['img_size'],\n",
    "        device=VEHICLE_CONFIG['device'],\n",
    "        patience=VEHICLE_CONFIG['patience'],\n",
    "        save_period=VEHICLE_CONFIG['save_period'],\n",
    "        project=VEHICLE_CONFIG['project'],\n",
    "        name=VEHICLE_CONFIG['name'],\n",
    "        exist_ok=True\n",
    "    )\n",
    "    \n",
    "    print(\"✅ Vehicle Detection Training Completed!\")\n",
    "else:\n",
    "    print(\"❌ Vehicle Detection dataset not found\")"
   ]
  },
