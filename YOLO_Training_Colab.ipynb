    "## 📊 Dataset Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze dataset structure\n",
    "def analyze_dataset(dataset_path, dataset_name):\n",
    "    print(f\"\\n📊 {dataset_name} Dataset Analysis:\")\n",
    "    \n",
    "    # Count images in each split\n",
    "    splits = ['train', 'valid', 'test']\n",
    "    for split in splits:\n",
    "        img_path = os.path.join(dataset_path, split, 'images')\n",
    "        if os.path.exists(img_path):\n",
    "            num_images = len([f for f in os.listdir(img_path) if f.endswith(('.jpg', '.jpeg', '.png'))])\n",
    "            print(f\"  {split.capitalize()}: {num_images} images\")\n",
    "    \n",
    "    # Read data.yaml for class information\n",
    "    yaml_path = os.path.join(dataset_path, 'data.yaml')\n",
    "    if os.path.exists(yaml_path):\n",
    "        with open(yaml_path, 'r') as f:\n",
    "            print(f\"  Classes: {f.read()}\")\n",
    "\n",
    "# Analyze both datasets\n",
    "vehicle_path = \"/content/datasets/vehicle_detection/Vehicle Detection.v1i.yolov11\"\n",
    "plate_path = \"/content/datasets/number_plate/Indian number plate.v1i.yolov11\"\n",
    "\n",
    "if os.path.exists(vehicle_path):\n",
    "    analyze_dataset(vehicle_path, \"Vehicle Detection\")\n",
    "\n",
    "if os.path.exists(plate_path):\n",
    "    analyze_dataset(plate_path, \"Number Plate\")"
   ]
