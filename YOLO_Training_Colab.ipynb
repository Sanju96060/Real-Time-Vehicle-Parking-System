  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Test on Validation Set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test models on validation sets\n",
    "def test_model(model, dataset_path, model_name):\n",
    "    if model is None:\n",
    "        print(f\"❌ {model_name} model not loaded\")\n",
    "        return\n",
    "    \n",
    "    print(f\"\\n🧪 Testing {model_name} on validation set...\")\n",
    "    \n",
    "    # Run validation\n",
    "    metrics = model.val(data=os.path.join(dataset_path, 'data.yaml'))\n",
    "    \n",
    "    # Print metrics\n",
    "    print(f\"📊 {model_name} Validation Results:\")\n",
    "    print(f\"  mAP50: {metrics.box.map50:.4f}\")\n",
    "    print(f\"  mAP50-95: {metrics.box.map:.4f}\")\n",
    "    print(f\"  Precision: {metrics.box.mp:.4f}\")\n",
    "    print(f\"  Recall: {metrics.box.mr:.4f}\")\n",
    "    \n",
    "    return metrics\n",
    "\n",
    "# Test Vehicle Detection\n",
    "if vehicle_model and os.path.exists(vehicle_path):\n",
    "    vehicle_metrics = test_model(vehicle_model, vehicle_path, \"Vehicle Detection\")\n",
    "\n",
    "# Test Number Plate Detection\n",
    "if plate_model and os.path.exists(plate_path):\n",
    "    plate_metrics = test_model(plate_model, plate_path, \"Number Plate Detection\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Conditional Testing Scenarios"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test on various conditions\n",
    "def test_conditions(model, test_images_path, model_name, conditions):\n",
    "    if model is None or not os.path.exists(test_images_path):\n",
    "        print(f\"❌ Cannot test {model_name} - model or test images not found\")\n",
    "        return\n",
    "    \n",
    "    print(f\"\\n🔬 {model_name} - Testing under conditions:\")\n",
    "    \n",
    "    test_images = [f for f in os.listdir(test_images_path) if f.endswith(('.jpg', '.jpeg', '.png'))]\n",
    "    \n",
    "    for condition in conditions:\n",
    "        print(f\"\\n  📋 Testing: {condition}\")\n",
    "        \n",
    "        # Test on a few images\n",
    "        for img_file in test_images[:3]:  # Test first 3 images\n",
    "            img_path = os.path.join(test_images_path, img_file)\n",
    "            \n",
    "            # Run inference\n",
    "            results = model(img_path)\n",
    "            \n",
    "            # Count detections\n",
    "            detections = len(results[0].boxes)\n",
    "            \n",
    "            print(f\"    {img_file}: {detections} detections\")\n",
    "            \n",
    "            # Optional: Display results\n",
    "            if detections > 0:\n",
    "                result_img = results[0].plot()\n",
    "                plt.figure(figsize=(10, 6))\n",
    "                plt.imshow(result_img)\n",
    "                plt.title(f'{model_name} - {condition} - {img_file}')\n",
    "                plt.axis('off')\n",
    "                plt.show()\n",
    "\n",
    "# Define test conditions\n",
    "TEST_CONDITIONS = [\n",
    "    \"Normal Lighting\",\n",
    "    \"Low Light\", \n",
    "    \"Different Angles\",\n",
    "    \"Partial Occlusion\",\n",
    "    \"Multiple Objects\",\n",
    "    \"Far Distance\",\n",
    "    \"Close Range\"\n",
    "]\n",
    "\n",
    "# Test Vehicle Detection\n",
    "if vehicle_model and os.path.exists(vehicle_path):\n",
    "    vehicle_test_path = os.path.join(vehicle_path, 'test', 'images')\n",
    "    test_conditions(vehicle_model, vehicle_test_path, \"Vehicle Detection\", TEST_CONDITIONS)\n",
    "\n",
    "# Test Number Plate Detection\n",
    "if plate_model and os.path.exists(plate_path):\n",
    "    plate_test_path = os.path.join(plate_path, 'test', 'images')\n",
    "    test_conditions(plate_model, plate_test_path, \"Number Plate Detection\", TEST_CONDITIONS)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🎯 Performance Benchmarking"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Benchmark model performance\n",
    "import time\n",
    "\n",
    "def benchmark_model(model, test_images_path, model_name):\n",
    "    if model is None or not os.path.exists(test_images_path):\n",
    "        print(f\"❌ Cannot benchmark {model_name}\")\n",
    "        return\n",
    "    \n",
    "    print(f\"\\n⚡ {model_name} Performance Benchmark:\")\n",
    "    \n",
    "    test_images = [f for f in os.listdir(test_images_path) if f.endswith(('.jpg', '.jpeg', '.png'))][:10]\n",
    "    \n",
    "    times = []\n",
    "    total_detections = 0\n",
    "    \n",
    "    for img_file in test_images:\n",
    "        img_path = os.path.join(test_images_path, img_file)\n",
    "        \n",
    "        # Measure inference time\n",
    "        start_time = time.time()\n",
    "        results = model(img_path)\n",
    "        end_time = time.time()\n",
    "        \n",
    "        inference_time = end_time - start_time\n",
    "        times.append(inference_time)\n",
    "        total_detections += len(results[0].boxes)\n",
    "        \n",
    "        print(f\"  {img_file}: {inference_time:.3f}s, {len(results[0].boxes)} detections\")\n",
    "    \n",
    "    # Calculate statistics\n",
    "    avg_time = np.mean(times)\n",
    "    fps = 1 / avg_time\n",
    "    \n",
    "    print(f\"\\n📊 {model_name} Benchmark Results:\")\n",
    "    print(f\"  Average Inference Time: {avg_time:.3f}s\")\n",
    "    print(f\"  FPS: {fps:.1f}\")\n",
    "    print(f\"  Total Detections: {total_detections}\")\n",
    "    print(f\"  Average Detections per Image: {total_detections/len(test_images):.1f}\")\n",
    "\n",
    "# Benchmark both models\n",
    "if vehicle_model and os.path.exists(vehicle_path):\n",
    "    vehicle_test_path = os.path.join(vehicle_path, 'test', 'images')\n",
    "    benchmark_model(vehicle_model, vehicle_test_path, \"Vehicle Detection\")\n",
    "\n",
    "if plate_model and os.path.exists(plate_path):\n",
    "    plate_test_path = os.path.join(plate_path, 'test', 'images')\n",
    "    benchmark_model(plate_model, plate_test_path, \"Number Plate Detection\")"
   ]
  },
