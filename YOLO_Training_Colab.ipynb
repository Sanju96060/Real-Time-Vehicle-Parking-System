   "metadata": {},
   "outputs": [],
   "source": [
    "# Export models for deployment\n",
    "def export_model(model, model_name, format='onnx'):\n",
    "    if model is None:\n",
    "        print(f\"❌ Cannot export {model_name} - model not loaded\")\n",
    "        return\n",
    "    \n",
    "    print(f\"\\n💾 Exporting {model_name} to {format.upper()} format...\")\n",
    "    \n",
    "    try:\n",
    "        # Export model\n",
    "        exported_path = model.export(format=format, imgsz=640)\n",
    "        print(f\"✅ {model_name} exported to: {exported_path}\")\n",
    "        \n",
    "        # Check file size\n",
    "        if os.path.exists(exported_path):\n",
    "            size_mb = os.path.getsize(exported_path) / (1024 * 1024)\n",
    "            print(f\"  File size: {size_mb:.2f} MB\")\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f\"❌ Export failed: {e}\")\n",
    "\n",
    "# Export both models\n",
    "export_model(vehicle_model, \"Vehicle Detection\")\n",
    "export_model(plate_model, \"Number Plate Detection\")\n",
    "\n",
    "# Also export to other formats if needed\n",
    "# export_model(vehicle_model, \"Vehicle Detection\", 'torchscript')\n",
    "# export_model(plate_model, \"Number Plate Detection\", 'torchscript')"
   ]
  },
