    "        plt.title(f'{model_name} Training Results', fontsize=16)\n",
    "        plt.axis('off')\n",
    "        plt.show()\n",
    "    else:\n",
    "        print(f\"❌ Results not found for {model_name}\")\n",
    "\n",
    "# Display training results\n",
    "plot_training_results('runs/detect', 'yolov11_vehicle')\n",
